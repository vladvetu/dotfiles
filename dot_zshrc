### Added by Zinit's installer
if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    print -P "%F{33} %F{220}Installing %F{33}ZDHARMA-CONTINUUM%F{220} Initiative Plugin Manager (%F{33}zdharma-continuum/zinit%F{220})…%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$HOME/.local/share/zinit/zinit.git" && \
        print -P "%F{33} %F{34}Installation successful.%f%b" || \
        print -P "%F{160} The clone has failed.%f%b"
fi

source "$HOME/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# first include some defaults
source "$HOME/.config/zsh/defaults.zsh"

typeset -ga sources
sources+="$ZSH_CONFIG/environment.zsh"
sources+="$ZSH_CONFIG/function.d"
sources+="$ZSH_CONFIG/alias.d"
sources+="$ZSH_CONFIG/init.d"
sources+="$ZSH_CONFIG/completion.d"

# try to include all sources
#foreach item (`echo $sources`)
for item in $sources[@]; do
  echo "directory: $item"
  if [[ -d "$item" ]]; then
    for file in "$item/*.zsh"; do
      echo "file: $file"
      source $file
    done
  elif [[ -a "$item" ]]; then
  # sourceIncludeTimeStart=$(gdate +%s%N)
    echo "file: $item"
    source $item
  # sourceIncludeDuration=$((($(gdate +%s%N) - $sourceIncludeTimeStart)/1000000))
  # echo $sourceIncludeDuration ms runtime for $file
  fi
end

